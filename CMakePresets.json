{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "mac-debug",
      "displayName": "macOS Debug (Ninja)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/mac-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_PREFIX_PATH": "/opt/homebrew/opt/qt"
      },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" }
    },
    {
      "name": "mac-release",
      "displayName": "macOS Release (Ninja)",
      "inherits": "mac-debug",
      "binaryDir": "${sourceDir}/build/mac-release",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "windows-msvc",
      "displayName": "Windows x64 (MSVC)",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-msvc",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" }
    }
  ],
  "buildPresets": [
    { "name": "mac-debug", "configurePreset": "mac-debug" },
    { "name": "mac-release", "configurePreset": "mac-release" },
    { "name": "windows-msvc", "configurePreset": "windows-msvc", "configuration": "Release" }
  ],
  "testPresets": [
    { "name": "mac-debug", "configurePreset": "mac-debug", "output": { "outputOnFailure": true } },
    { "name": "windows-msvc", "configurePreset": "windows-msvc", "configuration": "Release", "output": { "outputOnFailure": true } }
  ]
}
